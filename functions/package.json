{
  "name": "backend",
  "version": "1.0.0",
  "description": "Production-ready backend with PostgreSQL, Prisma, and Express",
  "main": "dist/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
