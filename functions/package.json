    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.0.6",
    "google-auth-library": "^9.10.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "resend": "^6.9.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
